{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.2"
    },
    "*.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "routes": [
    { "src": "/", "dest": "/index.php" },
    { "src": "/api/([^/]+)\\.php(.*)", "dest": "/api/$1.php$2" },
    { "src": "/([^/]+)\\.php(.*)", "dest": "/$1.php$2" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
