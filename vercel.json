{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)\\.php",
      "dest": "/api/$1.php"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}

{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.1"
    },
    "*.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "routes": [
    { "src": "/", "dest": "/index.php" },
    { "src": "/api/([^/]+)\\.php(.*)", "dest": "/api/$1.php$2" },
    { "src": "/([^/]+)\\.php(.*)", "dest": "/$1.php$2" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}